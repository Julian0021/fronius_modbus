  "issues": {
    "legacy_modbus_only_entry_reconfigure": {
      "title": "Review Fronius web API access",
      "fix_flow": {
        "step": {
          "init": {
            "title": "Review Fronius System",
            "description": "The entry \"{entry_title}\" needs a valid customer token. Review the host, update interval, and Modbus IP restriction. The next step asks for the customer password only if needed.",
