        }
      }
    },
    "solar_api_low_firmware": {
      "title": "Disable Fronius Solar API on older firmware",
      "fix_flow": {
        "step": {
          "init": {
            "title": "Disable Solar API",
            "description": "The inverter \"{entry_title}\" is running firmware {current_version}, which is below the safe minimum {minimum_version}. When Solar API stays enabled on older firmware it can cause a memory leak and inverter outages over time. Choose whether to disable Solar API now or ignore this warning.",
            "menu_options": {
              "fix": "Disable Solar API",
              "ignore": "Ignore warning"
            },
            "menu_option_descriptions": {
              "fix": "Recommended for firmware below {minimum_version}.",
              "ignore": "Keep Solar API enabled and hide this warning for now."
            }
          },
          "confirm": {
            "title": "Disable Solar API",
            "description": "Press Submit to disable Solar API on the inverter \"{entry_title}\".",
            "submit": "Disable Solar API",
            "data": {}
          }
        },
        "error": {
          "cannot_connect": "Failed to connect to the inverter.",
          "invalid_api_credentials": "Customer login failed.",
          "cannot_confirm_disable": "Could not confirm that Solar API was disabled.",
          "unknown": "Unknown error"
        },
        "abort": {
          "entry_not_found": "The Fronius entry no longer exists.",
          "issue_ignored": "The warning was ignored. You can unignore it later from Repairs."
        },
        "create_entry": {
          "default": "Solar API disabled successfully."
        }
      }
    }
