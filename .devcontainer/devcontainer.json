{
  "name": "fronius-modbus-ha-tests",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bullseye",
  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install -r requirements-dev-ha.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "tests_ha"
        ]
      }
    }
  }
}
